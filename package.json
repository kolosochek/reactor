{
  "name": "reactor-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Reactor: Idea-Transformer microservice and ecosystem",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "db:up": "docker compose up -d reactor-postgres",
    "db:down": "docker compose down reactor-postgres",
    "db:generate": "npm run db:generate -w @reactor/service",
    "db:migrate": "npm run db:migrate -w @reactor/service",
    "service:start": "npm run start -w @reactor/service"
  }
}
